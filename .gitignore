# Terraform configuration files and directories
#
# Local Terraform directories
.terraform/
.terraform.lock.hcl

# Terraform state files (local)
terraform.tfstate
terraform.tfstate.backup

# Sensitive tfvars files
# Exclude all .tfvars files, which may contain sensitive data
# such as passwords, private keys, and other secrets.
# If you have non-sensitive tfvars files, you can negate
# specific files like "!variables.tfvars"
*.tfvars
*.tfvars.json

# Crash log files
crash.log

# Ignore TF plan files (if they are saved to disk)
# e.g., terraform plan -out=tfplan
*.tfplan

# Ignore files generated by the "terraform debug" command
.tfdebug/

# Optional: Ignore files generated by the "terraform providers mirror" command
# .terraform/providers/

# Optional: Ignore any other files you might generate locally
# such as editor-specific files (e.g., .vscode/, *.swp) or OS-specific files (.DS_Store, Thumbs.db)
